{
  "manifest_version": 3,
  "name": "AutoNext - Progress Bar Auto Clicker",
  "version": "1.0.0",
  "description": "Read one progress bar, click one permanent NEXT spot at 100%, and dismiss one mapped OK popup.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoNext"
  }
}
